# name: test/sql/named_instance/resolve_unknown.test
# description: Spec 045 - unknown instance name produces InstanceNotFound error at ATTACH time

require mssql

require-env NAMED_INSTANCE_TEST

# Mock browser only advertises TESTINST and SECONDARY; NONESUCH must fail fast.
statement error
ATTACH 'Server=browser.example.com\NONESUCH;Database=NamedInstTest;User Id=sa;Password=TestPassword1;Encrypt=no' AS bad (TYPE mssql);
