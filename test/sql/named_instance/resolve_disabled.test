# name: test/sql/named_instance/resolve_disabled.test
# description: Spec 045 FR-012 - mssql_named_instance_resolution=false rejects host\instance at parse time

require mssql

require-env NAMED_INSTANCE_TEST

statement ok
SET mssql_named_instance_resolution=false;

statement error
ATTACH 'Server=browser.example.com\TESTINST;Database=NamedInstTest;User Id=sa;Password=TestPassword1;Encrypt=no' AS bad (TYPE mssql);
----
named-instance resolution is disabled

# Restore default and verify it works again.
statement ok
SET mssql_named_instance_resolution=true;

statement ok
ATTACH 'Server=browser.example.com\TESTINST;Database=NamedInstTest;User Id=sa;Password=TestPassword1;Encrypt=no' AS db (TYPE mssql);

statement ok
DETACH db;
