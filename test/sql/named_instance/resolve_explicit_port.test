# name: test/sql/named_instance/resolve_explicit_port.test
# description: Spec 045 FR-002 - explicit ,port bypasses SQL Server Browser even when instance is given

require mssql

require-env NAMED_INSTANCE_TEST

# Connect directly to SQL Server on its known port, including the instance name.
# The resolver must NOT contact the mock browser because the port is explicit;
# the instance name flows through to LOGIN7 ServerName but does not trigger UDP.
statement ok
ATTACH 'Server=sql.example.com\TESTINST,11433;Database=NamedInstTest;User Id=sa;Password=TestPassword1;Encrypt=no' AS db (TYPE mssql);

query II
SELECT id, payload FROM db.dbo.Probe;
----
1	spec045 lives

statement ok
DETACH db;
