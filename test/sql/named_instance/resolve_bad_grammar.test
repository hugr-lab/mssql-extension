# name: test/sql/named_instance/resolve_bad_grammar.test
# description: Spec 045 FR-010 - reject instance names outside [A-Za-z0-9_$#]{1,16}

require mssql

require-env NAMED_INSTANCE_TEST

# Empty instance after backslash
statement error
ATTACH 'Server=browser.example.com\;Database=db;User Id=sa;Password=TestPassword1' AS bad1 (TYPE mssql);
----
empty instance name

# Non-grammar character
statement error
ATTACH 'Server=browser.example.com\bad-instance;Database=db;User Id=sa;Password=TestPassword1' AS bad2 (TYPE mssql);
----
invalid character

# Too long (>16 chars)
statement error
ATTACH 'Server=browser.example.com\AAAAAAAAAAAAAAAAA;Database=db;User Id=sa;Password=TestPassword1' AS bad3 (TYPE mssql);
----
longer than 16
