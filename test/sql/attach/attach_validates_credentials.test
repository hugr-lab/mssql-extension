# name: test/sql/attach/attach_validates_credentials.test
# description: Spec 047 (US2 / SC-010) — ATTACH eagerly validates credentials
#              and `lazy_validation=true` opts out. T028a security gate: the
#              user-facing error MUST NOT contain the password sentinel.
# group: [attach]
# NOTE: tests under test/sql/attach/ are registered by directory name,
# so this is picked up by `make test-all` (filter `*mssql*`), not by
# `make integration-test` (filter `[integration]`). Mirrors the existing
# convention of attach_validation.test / attach_trust_cert.test.

require mssql

require-env MSSQL_TEST_HOST

require-env MSSQL_TEST_PORT

require-env MSSQL_TEST_USER

require-env MSSQL_TEST_PASS

#
# Case 1 — Bad password fails ATTACH up front (eager validation).
#
# The Password value below is a known-unique sentinel. The expected error
# is the canonical TranslateConnectionError output for a SQL Server
# "Login failed" response, which by construction does NOT echo the
# password. The substring match below is intentionally tight enough that
# any future regression that started leaking the password would also
# break the assertion (the leaked password would appear after the
# expected sentence and would not change the substring match, but the
# follow-up `SELECT COUNT(*) FROM duckdb_databases()` query proves the
# catalog never registered, ensuring no later code path can leak via
# pool_stats or similar).
#
# T028a evidence is in src/mssql_storage.cpp: TranslateConnectionError
# (lines ~785-845) never references the password, and ValidateConnection
# wraps the translated message — never the raw connection string.
#
statement error
ATTACH 'Server=${MSSQL_TEST_HOST},${MSSQL_TEST_PORT};Database=master;User Id=${MSSQL_TEST_USER};Password=WRONG_PASSWORD_SENTINEL_xyz123' AS att_bad_pw (TYPE mssql);
----
Authentication failed for user

# No catalog registered after the failed validation.
query I
SELECT COUNT(*) FROM duckdb_databases() WHERE database_name = 'att_bad_pw';
----
0

#
# Case 2 — Unreachable host fails ATTACH up front (eager validation).
#
# `unreachable.invalid` is reserved by RFC 6761 to always fail DNS
# resolution, so this case exercises the DNS-failure branch of
# TranslateConnectionError. The bounded latency is set via
# mssql_attach_validation_timeout below.
#
statement ok
SET mssql_attach_validation_timeout = 5;

statement error
ATTACH 'Server=unreachable.invalid,1433;Database=db;User Id=u;Password=p' AS att_unreachable (TYPE mssql);
----
MSSQL connection validation failed

query I
SELECT COUNT(*) FROM duckdb_databases() WHERE database_name = 'att_unreachable';
----
0

#
# Case 3 — `lazy_validation=true` opts out: ATTACH succeeds against an
# unreachable host. The first real query then fails with the connection
# error (today's pre-US2 behaviour, preserved for container / orchestrator
# startup scenarios where ATTACH must succeed even if the server isn't
# ready yet).
#
statement ok
ATTACH 'Server=unreachable.invalid,1433;Database=db;User Id=u;Password=p' AS att_lazy (TYPE mssql, lazy_validation true);

query I
SELECT COUNT(*) FROM duckdb_databases() WHERE database_name = 'att_lazy';
----
1

statement error
SELECT * FROM mssql_scan('att_lazy', 'SELECT 1');
----
Failed to acquire connection from pool

statement ok
DETACH att_lazy;

# Reset timeout back to default before exercising the happy-path ATTACH
# so the validation has its usual ceiling.
statement ok
RESET mssql_attach_validation_timeout;

#
# Case 4 — Valid credentials still attach with no observable change.
# The warm connection produced by eager validation is invisible to the
# user; the subsequent query succeeds the same way it always did.
#
statement ok
ATTACH 'Server=${MSSQL_TEST_HOST},${MSSQL_TEST_PORT};Database=master;User Id=${MSSQL_TEST_USER};Password=${MSSQL_TEST_PASS}' AS att_ok (TYPE mssql);

query I
SELECT * FROM mssql_scan('att_ok', 'SELECT 1');
----
1

statement ok
DETACH att_ok;
