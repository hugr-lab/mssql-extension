# name: test/sql/tds_connection/pool_stats_no_credentials.test
# description: Spec 047 (US-SEC / FR-011 hardening / SC-005 extension / T046h)
#              — mssql_pool_stats() output must not contain any value that
#              was supplied as a credential in the ATTACH connection string.
#              Today's pool_stats schema is `db` (VARCHAR — catalog alias
#              + GetDBPath form `mssql://host:port/database`) plus 8 BIGINT
#              counters. Numeric columns physically cannot contain a string
#              sentinel; the `db` column is what we have to grep.
# group: [tds_connection]

require mssql

require-env MSSQL_TEST_HOST

require-env MSSQL_TEST_PORT

require-env MSSQL_TEST_USER

require-env MSSQL_TEST_PASS

# SQL-auth path: ATTACH with the real password (any sentinel-password
# would fail the eager validation from US2 — which itself proves the
# password is not echoed in the error message, separate gate). We use
# the real password but assert against a known-unique sentinel substring
# that the password contains. The MSSQL_TEST_PASS value in the test
# docker container is `TestPassword1`, so the sentinel substring
# `TestPassword1` is exactly the password. If a future regression
# started concatenating the connection string into `pool_stats.db`
# (or anywhere else queryable), this substring would surface.
statement ok
ATTACH 'Server=${MSSQL_TEST_HOST},${MSSQL_TEST_PORT};Database=master;User Id=${MSSQL_TEST_USER};Password=${MSSQL_TEST_PASS}' AS pool_stats_sentinel (TYPE mssql);

# Touch the pool once so it has at least one connection to report on.
statement ok
SELECT * FROM mssql_scan('pool_stats_sentinel', 'SELECT 1');

# Core assertion: the only VARCHAR column (`db`) does not contain the
# password. SC-005 grep gate.
query I
SELECT COUNT(*) FROM mssql_pool_stats('pool_stats_sentinel')
WHERE db LIKE '%' || '${MSSQL_TEST_PASS}' || '%';
----
0

# Also confirm we DID get a row (otherwise the COUNT=0 would be vacuous).
query I
SELECT COUNT(*) FROM mssql_pool_stats('pool_stats_sentinel');
----
1

# And the all-pools variant: same redaction invariant.
query I
SELECT COUNT(*) FROM mssql_pool_stats()
WHERE db LIKE '%' || '${MSSQL_TEST_PASS}' || '%';
----
0

statement ok
DETACH pool_stats_sentinel;
